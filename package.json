{
  "name": "babloo-v2",
  "private": true,
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "lint": "turbo lint",
    "test": "turbo test",
    "db:generate": "corepack pnpm --filter @babloo/api exec prisma generate",
    "db:migrate": "corepack pnpm --filter @babloo/api exec prisma migrate dev",
    "db:seed": "corepack pnpm --filter @babloo/api exec prisma db seed",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down"
  },
  "devDependencies": {
    "turbo": "^2.3.0",
    "typescript": "^5.7.0"
  },
  "packageManager": "pnpm@9.15.0"
}
